KEY_RESULT = "processing_result"
KEY_REPORTS = "validation_reports"


def _render_header() -> None:
    """Render the title, icon, instructions and sample-file downloads."""
    st.set_page_config(page_title=APP_TITLE, page_icon=APP_ICON, layout="wide")
    st.title(f"{APP_ICON} {APP_TITLE}")
    st.caption(APP_DESCRIPTION)

    with st.expander("ℹ️  How to use / get sample files", expanded=False):
        st.markdown(
            "1. Upload each Excel file into its slot.\n"
            "2. Click **Validate**, then **Process**.\n"
            "3. **Copy**, or download the result as Excel or CSV.\n\n"
            "No files handy? Download these ready-made samples and upload them:"
        )
        col1, col2 = st.columns(2)
        with col1:
            st.download_button(
                "⬇️ Sample: Trade Blotter",
                data=dataframe_to_excel_bytes(build_sample_trade_blotter(), FILE_1.sheet_name),
                file_name="input_file_1.xlsx",
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                use_container_width=True,
            )
        with col2:
            st.download_button(
                "⬇️ Sample: Asset Reference",
                data=dataframe_to_excel_bytes(build_sample_asset_reference(), FILE_2.sheet_name),
                file_name="input_file_2.xlsx",
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                use_container_width=True,
            )


def _render_uploaders() -> Dict[str, Optional[object]]:
    """Render one uploader per configured input file."""
    st.subheader("1 · Upload files")
    sources: Dict[str, Optional[object]] = {}
    columns = st.columns(len(INPUT_FILES))
    for spec, column in zip(INPUT_FILES, columns):
        with column:
            sources[spec.label] = st.file_uploader(
                f"**{spec.label}**  ·  sheet: `{spec.sheet_name}`",
                type=["xlsx", "xls"], key=f"upload_{spec.label}",
            )
    return sources


def _all_uploaded(sources: Dict[str, Optional[object]]) -> bool:
    """Return ``True`` only if every configured file has been provided."""
    return all(sources.get(spec.label) is not None for spec in INPUT_FILES)


def _render_reports(reports: List[ValidationReport]) -> None:
    """Display validation errors and warnings in a friendly way."""
    for report in reports:
        if report.is_valid and not report.warnings:
            st.success(f"✅ '{report.file_label}' passed validation.")
            continue
        for message in report.errors:
            st.error(f"❌ {message}")
        for message in report.warnings:
            st.warning(f"⚠️ {message}")


def _render_copy_button(df: pd.DataFrame) -> None:
    """Render a 'Copy table' button that copies TSV to the clipboard."""
    payload = json.dumps(dataframe_to_tsv(df))
    components.html(
        f"""
        <button id="copy-btn" style="padding:0.5rem 1rem;border:1px solid #ccc;
            border-radius:0.5rem;background:#f6f6f6;cursor:pointer;font-size:0.9rem;">
            📋 Copy table
        </button>
        <span id="copy-msg" style="margin-left:0.6rem;color:#0a7d33;"></span>
        <script>
            const data = {payload};
            document.getElementById("copy-btn").addEventListener("click", async () => {{
                try {{
                    await navigator.clipboard.writeText(data);
                    document.getElementById("copy-msg").textContent = "Copied!";
                }} catch (e) {{
                    document.getElementById("copy-msg").textContent = "Copy failed";
                }}
            }});
        </script>
        """,
        height=48,
    )


def _render_output(result: ProcessingResult) -> None:
    """Render the output table plus copy/download controls."""
    if result.output is None:
        return
    st.subheader("3 · Output")
    st.success(f"{result.message}  (in {result.elapsed:.2f}s)")

    st.dataframe(build_display_styler(result.output), use_container_width=True, hide_index=True)
    _render_copy_button(result.output)

    excel_bytes = dataframe_to_excel_bytes(result.output, OUTPUT_SHEET_NAME)
    csv_bytes = dataframe_to_csv_bytes(result.output)
    col_xlsx, col_csv = st.columns(2)
    with col_xlsx:
        st.download_button(
            "⬇️  Download Excel", data=excel_bytes, file_name="output.xlsx",
            mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            use_container_width=True,
        )
    with col_csv:
        st.download_button(
            "⬇️  Download CSV", data=csv_bytes, file_name="output.csv",
            mime="text/csv", use_container_width=True,
        )


def _handle_validate(sources: Dict[str, Optional[object]]) -> None:
    """Run validation only and store the reports."""
    with st.spinner("Validating files…"):
        reports = DataProcessor().validate(sources)  # type: ignore[arg-type]
    st.session_state[KEY_REPORTS] = reports
    st.session_state.pop(KEY_RESULT, None)


def _handle_process(sources: Dict[str, Optional[object]]) -> None:
    """Run the full pipeline and store the result."""
    with st.spinner("Processing…"):
        result = DataProcessor().run(sources)  # type: ignore[arg-type]
    st.session_state[KEY_RESULT] = result
    st.session_state[KEY_REPORTS] = result.reports


def _handle_reset() -> None:
    """Clear all app state and uploaders."""
    st.session_state.clear()
    st.rerun()


def main() -> None:
    """Compose and run the Streamlit page."""
    _render_header()
    sources = _render_uploaders()

    st.subheader("2 · Actions")
    ready = _all_uploaded(sources)
    if not ready:
        st.info("Upload every file to enable validation and processing.")

    col_validate, col_process, col_reset = st.columns(3)
    with col_validate:
        if st.button("🔍 Validate", disabled=not ready, use_container_width=True):
            _handle_validate(sources)
    with col_process:
        if st.button("⚙️ Process", type="primary", disabled=not ready, use_container_width=True):
            _handle_process(sources)
    with col_reset:
        if st.button("♻️ Reset", use_container_width=True):
            _handle_reset()

    reports = st.session_state.get(KEY_REPORTS)
    if reports:
        st.markdown("#### Validation")
        _render_reports(reports)

    result: Optional[ProcessingResult] = st.session_state.get(KEY_RESULT)
    if result and result.success:
        _render_output(result)
    elif result and not result.success and not reports:
        st.error(result.message)


if __name__ == "__main__":
    main()