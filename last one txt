def calculate_market_value(df: pd.DataFrame) -> pd.Series:
    """market_value = amount * price."""
    return df[COL_AMOUNT] * df[COL_PRICE]


def calculate_fx(df: pd.DataFrame) -> pd.Series:
    """fx_value = market_value * fx_rate (reporting-currency conversion)."""
    return calculate_market_value(df) * df[COL_FX_RATE]


def calculate_exposure(df: pd.DataFrame) -> pd.Series:
    """exposure = amount * price * fx_rate."""
    return df[COL_AMOUNT] * df[COL_PRICE] * df[COL_FX_RATE]


def calculate_haircut(df: pd.DataFrame) -> pd.Series:
    """haircut_amount = exposure * haircut."""
    return calculate_exposure(df) * df[COL_HAIRCUT]


def calculate_collateral(df: pd.DataFrame) -> pd.Series:
    """collateral = exposure * (1 - haircut)."""
    return calculate_exposure(df) * (1.0 - df[COL_HAIRCUT])


def calculate_margin(df: pd.DataFrame) -> pd.Series:
    """margin = collateral - exposure (negative == under-collateralised)."""
    return calculate_collateral(df) - calculate_exposure(df)


def calculate_cash_requirement(df: pd.DataFrame) -> pd.Series:
    """cash_requirement = exposure - collateral."""
    return calculate_exposure(df) - calculate_collateral(df)


def calculate_weighted_average(df: pd.DataFrame) -> pd.Series:
    """Amount-weighted average price per asset: Σ(amount*price)/Σ(amount)."""
    weighted_values = df[COL_AMOUNT] * df[COL_PRICE]
    group = df[COL_ASSET]
    numerator = weighted_values.groupby(group).transform("sum")
    denominator = df[COL_AMOUNT].groupby(group).transform("sum")
    return numerator / denominator.replace(0, np.nan)


# CALCULATION PIPELINE — add a (logical_name, function) line to add a formula.
CALCULATION_PIPELINE: List[tuple] = [
    (COL_MARKET_VALUE, calculate_market_value),
    (COL_EXPOSURE, calculate_exposure),
    (COL_COLLATERAL, calculate_collateral),
    (COL_MARGIN, calculate_margin),
    (COL_CASH_REQUIREMENT, calculate_cash_requirement),
    (COL_WEIGHTED_AVG_PRICE, calculate_weighted_average),
]
