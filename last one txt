@dataclass
class ValidationIssue:
    """A single validation finding (``severity`` is 'error' or 'warning')."""

    severity: str
    message: str


@dataclass
class ValidationReport:
    """The collected result of validating one file."""

    file_label: str
    issues: List[ValidationIssue] = field(default_factory=list)

    def add_error(self, message: str) -> None:
        """Record a blocking error."""
        self.issues.append(ValidationIssue("error", message))

    def add_warning(self, message: str) -> None:
        """Record a non-blocking warning."""
        self.issues.append(ValidationIssue("warning", message))

    @property
    def errors(self) -> List[str]:
        """All blocking error messages."""
        return [i.message for i in self.issues if i.severity == "error"]

    @property
    def warnings(self) -> List[str]:
        """All non-blocking warning messages."""
        return [i.message for i in self.issues if i.severity == "warning"]

    @property
    def is_valid(self) -> bool:
        """``True`` when there are no blocking errors."""
        return not self.errors


class Validator:
    """Validate a DataFrame against an :class:`InputFileSpec`."""

    #: If fewer than this fraction of expected headers are present, assume
    #: the wrong file was uploaded and skip the remaining checks.
    WRONG_FILE_THRESHOLD: float = 0.5

    def validate(self, df: pd.DataFrame, spec: InputFileSpec) -> ValidationReport:
        """Run every configured check and return a :class:`ValidationReport`."""
        report = ValidationReport(file_label=spec.label)

        if df is None or df.empty:
            report.add_error(f"'{spec.label}' contains no rows of data.")
            return report

        expected_headers = set(spec.columns.values())
        present_headers = expected_headers & set(df.columns)
        coverage = len(present_headers) / max(len(expected_headers), 1)
        if coverage < self.WRONG_FILE_THRESHOLD:
            report.add_error(
                f"This does not look like the '{spec.label}' file. "
                f"Expected columns like: {', '.join(sorted(expected_headers))}."
            )
            return report

        self._check_required_columns(df, spec, report)
        self._check_empty_values(df, spec, report)
        self._check_numeric(df, spec, report)
        self._check_dates(df, spec, report)
        self._check_duplicates(df, spec, report)

        logger.info(
            "Validation of '%s': %d error(s), %d warning(s)",
            spec.label, len(report.errors), len(report.warnings),
        )
        return report

    def _check_required_columns(self, df, spec, report) -> None:
        """Flag any required column whose Excel header is absent."""
        for logical in spec.required:
            header = spec.header_for(logical)
            if header not in df.columns:
                report.add_error(f"'{spec.label}': required column '{header}' is missing.")

    def _check_empty_values(self, df, spec, report) -> None:
        """Flag blank cells in required columns."""
        for logical in spec.required:
            header = spec.header_for(logical)
            if header not in df.columns:
                continue
            blank = int(df[header].isna().sum())
            if blank:
                report.add_error(
                    f"'{spec.label}': column '{header}' has {blank} empty value(s)."
                )

    def _check_numeric(self, df, spec, report) -> None:
        """Flag non-numeric entries in numeric columns."""
        for logical in spec.numeric:
            header = spec.header_for(logical)
            if header not in df.columns:
                continue
            coerced = pd.to_numeric(df[header], errors="coerce")
            bad = coerced.isna() & df[header].notna()
            if bad.any():
                rows = (bad[bad].index + 2).tolist()
                preview = ", ".join(map(str, rows[:5]))
                report.add_error(
                    f"'{spec.label}': column '{header}' has non-numeric value(s) "
                    f"at row(s) {preview}" + ("…" if len(rows) > 5 else "")
                )

    def _check_dates(self, df, spec, report) -> None:
        """Flag unparseable entries in date columns (as warnings)."""
        for logical in spec.dates:
            header = spec.header_for(logical)
            if header not in df.columns:
                continue
            coerced = pd.to_datetime(df[header], errors="coerce")
            bad = coerced.isna() & df[header].notna()
            if bad.any():
                rows = (bad[bad].index + 2).tolist()
                preview = ", ".join(map(str, rows[:5]))
                report.add_warning(
                    f"'{spec.label}': column '{header}' has unrecognised date(s) "
                    f"at row(s) {preview}" + ("…" if len(rows) > 5 else "")
                )

    def _check_duplicates(self, df, spec, report) -> None:
        """Flag duplicate values in the configured unique-key column."""
        if spec.unique_key is None:
            return
        header = spec.header_for(spec.unique_key)
        if header not in df.columns:
            return
        dup_mask = df[header].duplicated(keep=False)
        if dup_mask.any():
            dups = df.loc[dup_mask, header].dropna().unique().tolist()
            preview = ", ".join(map(str, dups[:5]))
            report.add_error(
                f"'{spec.label}': duplicate '{header}' value(s): {preview}"
                + ("…" if len(dups) > 5 else "")
            )


