def assemble_output(df: pd.DataFrame) -> pd.DataFrame:
    """Build the final output table from ``OUTPUT_COLUMNS`` (native types)."""
    columns: Dict[str, Any] = {spec.name: _build_column(df, spec) for spec in OUTPUT_COLUMNS}
    output = pd.DataFrame(columns, index=df.index)
    logger.info("Assembled output table (%d rows x %d cols)", *output.shape)
    return output.reset_index(drop=True)


def _build_column(df: pd.DataFrame, spec: OutputColumn) -> pd.Series:
    """Return the Series for one output column according to its type."""
    if spec.kind in (ColumnType.DIRECT, ColumnType.CALCULATED):
        if spec.source in df.columns:
            return df[spec.source]
        logger.warning("Output source '%s' not found; filling NA", spec.source)
        return pd.Series(pd.NA, index=df.index)
    if spec.kind is ColumnType.CONSTANT:
        return pd.Series(spec.value, index=df.index)
    if spec.kind is ColumnType.BLANK:
        return pd.Series(pd.NA, index=df.index)
    if spec.kind is ColumnType.CONDITIONAL:
        assert spec.condition is not None, "CONDITIONAL column needs a callable"
        return df.apply(spec.condition, axis=1)
    raise ValueError(f"Unknown column type: {spec.kind}")  # pragma: no cover


def build_display_styler(raw: pd.DataFrame) -> Styler:
    """Wrap the raw output in a Styler (formatting + highlighting)."""
    formatters = {
        column: _make_formatter(rule)
        for column, rule in COLUMN_FORMATS.items()
        if column in raw.columns
    }
    styler = raw.style.format(formatter=formatters, na_rep=MISSING_VALUE_DISPLAY)
    return _apply_highlighting(styler, raw)


def _make_formatter(rule: Dict[str, Any]) -> Callable[[Any], str]:
    """Return a value->string formatter for one COLUMN_FORMATS rule."""
    kind = rule.get("kind", "number")

    def fmt(value: Any) -> str:
        if value is None or value is pd.NA or (isinstance(value, float) and pd.isna(value)):
            return MISSING_VALUE_DISPLAY
        try:
            if kind == "date":
                return pd.to_datetime(value).strftime(rule.get("format", "%Y-%m-%d"))
            if kind == "percent":
                return f"{value * 100:,.{rule.get('decimals', 2)}f}%"

            number = float(value)
            decimals = rule.get("decimals", 2)
            grouping = "," if rule.get("thousands", False) else ""
            body = f"{abs(number):{grouping}.{decimals}f}"
            symbol = rule.get("symbol", "") if kind == "currency" else ""

            if number < 0 and rule.get("negative") == "parentheses":
                return f"({symbol}{body})"
            sign = "-" if number < 0 else ""
            return f"{sign}{symbol}{body}"
        except (ValueError, TypeError):
            return str(value)

    return fmt


def _apply_highlighting(styler: Styler, raw: pd.DataFrame) -> Styler:
    """Apply every rule in ``HIGHLIGHT_RULES`` to the Styler."""
    for rule in HIGHLIGHT_RULES:
        column = rule["column"]
        if column not in raw.columns:
            continue
        predicate: Callable[[Any], bool] = rule["when"]
        css: str = rule["style"]

        def _style(value: Any, _pred=predicate, _css=css) -> str:
            try:
                return _css if _pred(value) else ""
            except (ValueError, TypeError):
                return ""

        styler = styler.map(_style, subset=[column])
    return styler


