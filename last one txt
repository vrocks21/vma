_LOGGER_NAME = "excel_app"
_F = TypeVar("_F", bound=Callable[..., Any])


def get_logger(name: str = _LOGGER_NAME) -> logging.Logger:
    """Return a process-wide singleton logger (console + optional file)."""
    logger_ = logging.getLogger(name)
    if logger_.handlers:
        return logger_

    logger_.setLevel(LOG_LEVEL)
    formatter = logging.Formatter(LOG_FORMAT)

    console = logging.StreamHandler()
    console.setFormatter(formatter)
    logger_.addHandler(console)

    if LOG_TO_FILE:
        try:
            file_handler = logging.FileHandler(LOG_FILE, encoding="utf-8")
            file_handler.setFormatter(formatter)
            logger_.addHandler(file_handler)
        except OSError:
            pass  # read-only filesystem (e.g. some hosts): console only

    logger_.propagate = False
    return logger_


logger = get_logger()


def timed(label: str | None = None) -> Callable[[_F], _F]:
    """Decorator that logs the wall-clock execution time of a function."""

    def decorator(func: _F) -> _F:
        @wraps(func)
        def wrapper(*args: Any, **kwargs: Any) -> Any:
            name = label or func.__name__
            start = time.perf_counter()
            try:
                return func(*args, **kwargs)
            finally:
                logger.info("⏱  %s finished in %.3fs", name, time.perf_counter() - start)

        return wrapper  # type: ignore[return-value]

    return decorator


def dataframe_to_excel_bytes(df: pd.DataFrame, sheet_name: str = "Output") -> bytes:
    """Serialise a DataFrame to in-memory ``.xlsx`` bytes (types preserved)."""
    buffer = io.BytesIO()
    with pd.ExcelWriter(buffer, engine="openpyxl") as writer:
        df.to_excel(writer, index=False, sheet_name=sheet_name)
    buffer.seek(0)
    return buffer.getvalue()


def dataframe_to_csv_bytes(df: pd.DataFrame) -> bytes:
    """Serialise a DataFrame to UTF-8 CSV bytes."""
    return df.to_csv(index=False).encode("utf-8")


def dataframe_to_tsv(df: pd.DataFrame) -> str:
    """Serialise a DataFrame to tab-separated text (for clipboard copy)."""
    return df.to_csv(index=False, sep="\t")


def friendly_error(exc: Exception) -> str:
    """Turn an exception into a short, user-readable one-line message."""
    return f"{type(exc).__name__}: {exc}"


