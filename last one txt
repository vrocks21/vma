@dataclass(frozen=True)
class InputFileSpec:
    """Declarative description of one input Excel file.

    Attributes:
        label: Human-friendly name shown in the UI and logs.
        sheet_name: Worksheet to read from the uploaded workbook.
        columns: Mapping of ``logical_name -> Excel header``.
        required: Logical names that must be present and populated.
        numeric: Logical names that must be coercible to numbers.
        dates: Logical names that must be coercible to dates.
        unique_key: Logical name that must not contain duplicates
            (``None`` disables the check).
        merge_on: Logical name used to join this file onto the growing
            dataset (``None`` marks the base file — the first one).
        merge_how: Pandas merge strategy ("left", "inner", ...).
    """

    label: str
    sheet_name: str
    columns: Dict[str, str]
    required: List[str] = field(default_factory=list)
    numeric: List[str] = field(default_factory=list)
    dates: List[str] = field(default_factory=list)
    unique_key: Optional[str] = None
    merge_on: Optional[str] = None
    merge_how: str = "left"

    def header_for(self, logical: str) -> str:
        """Return the Excel header configured for a logical name."""
        return self.columns[logical]

    def logical_by_header(self) -> Dict[str, str]:
        """Return the inverse mapping ``Excel header -> logical name``."""
        return {header: logical for logical, header in self.columns.items()}


class ColumnType(str, Enum):
    """How an output column obtains its value."""

    DIRECT = "direct"            # copied straight from an input column
    CALCULATED = "calculated"    # produced by a calculation (SECTION 5)
    CONSTANT = "constant"        # a fixed literal value for every row
    BLANK = "blank"             # intentionally empty column
    CONDITIONAL = "conditional"  # value derived per-row by a callable


@dataclass(frozen=True)
class OutputColumn:
    """One column in the final output table.

    Attributes:
        name: The header shown to the user in the output table.
        kind: A :class:`ColumnType` describing how the value is derived.
        source: Logical column name (for DIRECT / CALCULATED columns).
        value: Literal value (for CONSTANT columns).
        condition: ``callable(row) -> value`` (for CONDITIONAL columns).
    """

    name: str
    kind: ColumnType
    source: Optional[str] = None
    value: Any = None
    condition: Optional[Callable[[pd.Series], Any]] = None


