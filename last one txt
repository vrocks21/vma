@dataclass
class ProcessingResult:
    """Outcome of a full processing run."""

    success: bool
    output: Optional[pd.DataFrame] = None
    reports: List[ValidationReport] = field(default_factory=list)
    message: str = ""
    elapsed: float = 0.0


class DataProcessor:
    """Coordinate reading, validating, merging and calculating."""

    def __init__(self, specs: Optional[List[InputFileSpec]] = None) -> None:
        self.specs = specs if specs is not None else INPUT_FILES
        self.validator = Validator()

    def validate(self, sources: Dict[str, WorkbookSource]) -> List[ValidationReport]:
        """Read and validate every file without running calculations."""
        reports: List[ValidationReport] = []
        for spec in self.specs:
            report = ValidationReport(file_label=spec.label)
            try:
                df = self._read(spec, sources.get(spec.label))
                report = self.validator.validate(df, spec)
            except (ExcelReadError, ValueError) as exc:
                report.add_error(friendly_error(exc))
            reports.append(report)
        return reports

    def run(self, sources: Dict[str, WorkbookSource]) -> ProcessingResult:
        """Execute the full pipeline, capturing timing and errors."""
        start = time.perf_counter()
        try:
            frames = {s.label: self._read(s, sources.get(s.label)) for s in self.specs}

            reports = [self.validator.validate(frames[s.label], s) for s in self.specs]
            if any(not r.is_valid for r in reports):
                return ProcessingResult(
                    success=False, reports=reports,
                    message="Validation failed — please fix the issues above.",
                    elapsed=time.perf_counter() - start,
                )

            prepared = {s.label: self._prepare(frames[s.label], s) for s in self.specs}
            merged = self._merge(prepared)
            enriched = run_calculations(merged)
            output = assemble_output(enriched)

            elapsed = time.perf_counter() - start
            logger.info("Pipeline complete in %.3fs", elapsed)
            return ProcessingResult(
                success=True, output=output, reports=reports,
                message=f"Processed {len(output)} row(s) successfully.", elapsed=elapsed,
            )
        except Exception as exc:  # noqa: BLE001 - top-level safety net
            logger.exception("Pipeline failed")
            return ProcessingResult(
                success=False, message=f"Processing error: {friendly_error(exc)}",
                elapsed=time.perf_counter() - start,
            )

    def _read(self, spec: InputFileSpec, source: Optional[WorkbookSource]) -> pd.DataFrame:
        """Read the configured sheet for one spec."""
        if source is None:
            raise ValueError(f"No file was provided for '{spec.label}'.")
        return ExcelReader(source).read_sheet(spec.sheet_name)

    def _prepare(self, df: pd.DataFrame, spec: InputFileSpec) -> pd.DataFrame:
        """Rename headers to logical names and coerce numeric/date types."""
        rename_map = spec.logical_by_header()
        keep = [h for h in spec.columns.values() if h in df.columns]
        prepared = df[keep].rename(columns=rename_map).copy()
        for logical in spec.numeric:
            if logical in prepared.columns:
                prepared[logical] = pd.to_numeric(prepared[logical], errors="coerce")
        for logical in spec.dates:
            if logical in prepared.columns:
                prepared[logical] = pd.to_datetime(prepared[logical], errors="coerce")
        return prepared

    def _merge(self, prepared: Dict[str, pd.DataFrame]) -> pd.DataFrame:
        """Merge all prepared frames into one, following config order."""
        merged: Optional[pd.DataFrame] = None
        for spec in self.specs:
            frame = prepared[spec.label]
            if merged is None:
                merged = frame
                continue
            merged = merged.merge(frame, on=spec.merge_on, how=spec.merge_how)
            logger.info("Merged '%s' on '%s' (%d rows)", spec.label, spec.merge_on, len(merged))
        assert merged is not None, "No input files configured"
        return merged


