WorkbookSource = Union[str, IO[bytes]]


class ExcelReadError(Exception):
    """Raised when a workbook cannot be opened or parsed."""


class SheetNotFoundError(ExcelReadError):
    """Raised when a requested worksheet does not exist in the workbook."""


class ExcelReader:
    """Read worksheets from a single Excel workbook.

    Example:
        >>> df = ExcelReader(uploaded_file).read_sheet("Trades")
    """

    def __init__(self, source: WorkbookSource, engine: str = "openpyxl") -> None:
        """Initialise the reader with a path or binary file-like object."""
        self._source = source
        self._engine = engine
        self._sheet_names: List[str] | None = None

    def sheet_names(self) -> List[str]:
        """Return (and cache) the workbook's worksheet names."""
        if self._sheet_names is None:
            try:
                self._rewind()
                with pd.ExcelFile(self._source, engine=self._engine) as xls:
                    self._sheet_names = list(xls.sheet_names)
            except Exception as exc:  # noqa: BLE001
                logger.error("Failed to open workbook: %s", exc)
                raise ExcelReadError(
                    "The uploaded file could not be opened as an Excel "
                    "workbook. Please check it is a valid .xlsx file."
                ) from exc
        return self._sheet_names

    def has_sheet(self, sheet_name: str) -> bool:
        """Return ``True`` if ``sheet_name`` exists in the workbook."""
        return sheet_name in self.sheet_names()

    def read_sheet(self, sheet_name: str) -> pd.DataFrame:
        """Read one worksheet into a DataFrame (headers stripped of spaces)."""
        if not self.has_sheet(sheet_name):
            available = ", ".join(self.sheet_names()) or "(none)"
            raise SheetNotFoundError(
                f"Sheet '{sheet_name}' was not found. Available sheets: {available}."
            )
        try:
            self._rewind()
            df = pd.read_excel(self._source, sheet_name=sheet_name, engine=self._engine)
        except Exception as exc:  # noqa: BLE001
            logger.error("Failed to read sheet '%s': %s", sheet_name, exc)
            raise ExcelReadError(f"Sheet '{sheet_name}' could not be read: {exc}") from exc

        logger.info("Read sheet '%s' (%d rows x %d cols)", sheet_name, *df.shape)
        df.columns = [str(c).strip() for c in df.columns]
        return df

    def read_sheets(self, sheet_names: List[str]) -> Dict[str, pd.DataFrame]:
        """Read several worksheets, returning ``{sheet_name: DataFrame}``."""
        return {name: self.read_sheet(name) for name in sheet_names}

    def _rewind(self) -> None:
        """Rewind a file-like source so it can be read more than once."""
        seek = getattr(self._source, "seek", None)
        if callable(seek):
            try:
                seek(0)
            except (OSError, ValueError):
                pass


