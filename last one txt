@timed("calculations")
def run_calculations(df: pd.DataFrame) -> pd.DataFrame:
    """Apply every registered calculation, returning a new DataFrame."""
    result = df.copy()
    for column_name, func in CALCULATION_PIPELINE:
        logger.info("Calculating '%s'", column_name)
        result[column_name] = func(result)
    return result


